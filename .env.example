# ─────────────────────────────────────────────────────────────
# Ojas Trading — Environment Configuration (copy to .env)
# ─────────────────────────────────────────────────────────────

# ---- Postgres ----
POSTGRES_USER=ojas
POSTGRES_PASSWORD=ojas_dev_password
POSTGRES_DB=ojas_trading
POSTGRES_PORT=5432

# Connection string used by Prisma (host=db inside docker network, localhost outside)
DATABASE_URL="postgresql://ojas:ojas_dev_password@localhost:5432/ojas_trading?schema=public"

# ---- API (NestJS) ----
API_PORT=4000
NODE_ENV=development

# JWT secrets — CHANGE THESE IN PRODUCTION (use `openssl rand -base64 48`)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS origin (frontend)
WEB_ORIGIN=http://localhost:3000

# ---- S3 / MinIO (S3-compatible storage) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ojas-documents
S3_FORCE_PATH_STYLE=true
MINIO_CONSOLE_PORT=9001

# ---- Frontend (Next.js) ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---- Seed admin (created by `npm run db:seed`) ----
SEED_ADMIN_EMAIL=admin@ojastrading.com
SEED_ADMIN_PASSWORD=Admin@12345
# Load demo products/parties/deals too. Leave unset (or false) in production so the
# app boots empty with just the admin login. Set true for local dev / demos.
SEED_DEMO=true
